component RoundIconButton inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> subtitle;
    in property <bool> primary: false;
    callback clicked;

    width: 132px;
    height: 132px;
    border-radius: 66px;
    background: touch.pressed
        ? (root.primary ? #256d93 : #20314a)
        : (root.primary ? #0f5f87 : #101a2d);
    border-width: 2px;
    border-color: root.primary ? #8fd3ff : #334766;

    Image {
        x: (parent.width - 36px) / 2;
        y: 22px;
        width: 36px;
        height: 36px;
        source: root.icon;
    }

    Text {
        x: 10px;
        y: 66px;
        width: parent.width - 20px;
        height: 26px;
        text: root.title;
        color: #f8fbff;
        font-size: 18px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Text {
        x: 12px;
        y: 94px;
        width: parent.width - 24px;
        height: 18px;
        text: root.subtitle;
        color: #a8c3d9;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component PanelButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    callback clicked;

    width: 104px;
    height: 44px;
    border-radius: 22px;
    background: touch.pressed
        ? (root.primary ? #23855a : #2b405e)
        : (root.primary ? #2ed37a : #142238);
    border-width: 1px;
    border-color: root.primary ? #a5ffc9 : #415674;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.primary ? #06140a : #f8fbff;
        font-size: 14px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component WifiRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> selected: false;
    callback clicked;

    width: 360px;
    height: 42px;
    border-radius: 12px;
    background: touch.pressed ? #273f60 : (root.selected ? #153755 : #0b1726);
    border-width: 1px;
    border-color: root.selected ? #78cfff : #20344d;

    Text {
        x: 14px;
        y: 4px;
        width: parent.width - 28px;
        height: 19px;
        text: root.title;
        color: #f8fbff;
        font-size: 14px;
        font-weight: 800;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    Text {
        x: 14px;
        y: 23px;
        width: parent.width - 28px;
        height: 15px;
        text: root.detail;
        color: root.selected ? #bde8ff : #8ca5bb;
        font-size: 10px;
        font-weight: 650;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component KeyButton inherits Rectangle {
    in property <string> label;
    callback clicked;

    width: 44px;
    height: 44px;
    border-radius: 22px;
    background: touch.pressed ? #35577c : #182842;
    border-width: 1px;
    border-color: #45617f;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #f8fbff;
        font-size: 14px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component StepButton inherits Rectangle {
    in property <string> label;
    callback clicked;

    width: 44px;
    height: 44px;
    border-radius: 22px;
    background: touch.pressed ? #2f5f84 : #16243b;
    border-width: 1px;
    border-color: touch.pressed ? #8fd3ff : #39506e;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: #ffffff;
        font-size: 19px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked();
        }
    }
}

component AdjustField inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <int> field-width: 66;
    callback increment;
    callback decrement;

    width: root.field-width * 1px;
    height: 136px;
    border-radius: 14px;
    background: #07111e;
    border-width: 1px;
    border-color: #1c314c;

    Text {
        x: 0px;
        y: 7px;
        width: parent.width;
        height: 16px;
        text: root.label;
        color: #88a4bd;
        font-size: 9px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    StepButton {
        x: (parent.width - self.width) / 2;
        y: 24px;
        label: "+";
        clicked => {
            root.increment();
        }
    }

    Text {
        x: 0px;
        y: 67px;
        width: parent.width;
        height: 25px;
        text: root.value;
        color: #f8fbff;
        font-size: 22px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    StepButton {
        x: (parent.width - self.width) / 2;
        y: 88px;
        label: "-";
        clicked => {
            root.decrement();
        }
    }
}

export component AppWindow inherits Window {
    in property <int> screen: 0;

    in property <string> time-text: "--:--:--";
    in property <string> date-text: "----/--/--";
    in property <string> status-text: "--月--日 --:--";
    in property <string> year-text: "----";
    in property <string> month-text: "--";
    in property <string> day-text: "--";
    in property <string> hour-text: "--";
    in property <string> minute-text: "--";
    in property <string> second-text: "--";
    in property <float> day-progress: 0;
    in property <float> second-progress: 0;

    in property <bool> wifi-connected: false;
    in property <bool> wifi-enabled: true;
    in property <bool> bluetooth-connected: false;
    in property <string> wifi-network-title: "未扫描";
    in property <string> wifi-network-detail: "点击扫描";
    in property <string> wifi-row0-title: "未扫描";
    in property <string> wifi-row0-detail: "";
    in property <bool> wifi-row0-selected: false;
    in property <string> wifi-row1-title: "";
    in property <string> wifi-row1-detail: "";
    in property <bool> wifi-row1-selected: false;
    in property <string> wifi-row2-title: "";
    in property <string> wifi-row2-detail: "";
    in property <bool> wifi-row2-selected: false;
    in property <string> wifi-manual-ssid: "<scan>";
    in property <string> wifi-password: "";
    in property <string> wifi-status: "WiFi 空闲";
    in property <string> wifi-status-detail: "";
    in property <string> wifi-edit-label: "编辑 SSID";
    in property <string> wifi-key-page: "1/8";
    in property <string> wifi-key0: "a";
    in property <string> wifi-key1: "b";
    in property <string> wifi-key2: "c";
    in property <string> wifi-key3: "d";
    in property <string> wifi-key4: "e";
    in property <string> wifi-key5: "f";
    in property <string> wifi-key6: "g";
    in property <string> wifi-key7: "h";
    in property <string> wifi-key8: "i";
    in property <string> wifi-key9: "j";
    in property <string> wifi-key10: "k";
    in property <string> wifi-key11: "l";
    in property <string> wifi-key12: "m";
    in property <string> wifi-key13: "n";
    in property <string> wifi-key14: "o";
    in property <string> wifi-key15: "p";
    in property <string> wifi-key16: "q";
    in property <string> wifi-key17: "r";
    in property <string> wifi-key18: "s";
    in property <string> wifi-key19: "t";
    in property <string> wifi-key20: "u";
    in property <string> wifi-key21: "v";
    in property <string> bluetooth-status: "蓝牙空闲";
    in property <string> about-detail: "ESP32-S3 Touch LCD 3.49";

    callback open-settings;
    callback open-wifi;
    callback open-bluetooth;
    callback open-time;
    callback open-about;
    callback back-home;
    callback back-settings;
    callback open-wifi-advanced;
    callback wifi-toggle;
    callback wifi-scan;
    callback wifi-select-network(int);
    callback wifi-prev-network;
    callback wifi-next-network;
    callback wifi-connect;
    callback wifi-disconnect;
    callback wifi-key(string);
    callback wifi-next-key-page;
    callback wifi-backspace;
    callback wifi-clear-input;
    callback wifi-edit-ssid;
    callback wifi-edit-password;
    callback bluetooth-refresh;
    callback adjust-year-down;
    callback adjust-year-up;
    callback adjust-month-down;
    callback adjust-month-up;
    callback adjust-day-down;
    callback adjust-day-up;
    callback adjust-hour-down;
    callback adjust-hour-up;
    callback adjust-minute-down;
    callback adjust-minute-up;
    callback adjust-second-down;
    callback adjust-second-up;
    callback confirm-adjust;
    callback cancel-adjust;
    in property <string> time-status: "调整 RTC 时间";

    width: 640px;
    height: 172px;
    background: #05070c;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #05070c;
    }

    Rectangle {
        visible: root.screen == 0;
        width: parent.width;
        height: parent.height;
        background: #05070c;

        Image {
            width: parent.width;
            height: parent.height;
            source: @image-url("assets/clock-background.png");
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #02051526;
        }

        Image {
            visible: root.wifi-connected;
            x: 462px;
            y: 9px;
            width: 21px;
            height: 15px;
            source: @image-url("assets/wifi.svg");
        }

        Image {
            visible: !root.wifi-connected;
            x: 462px;
            y: 9px;
            width: 21px;
            height: 15px;
            source: @image-url("assets/wifi.disconnected.svg");
        }

        Image {
            visible: root.bluetooth-connected;
            x: 496px;
            y: 7px;
            width: 15px;
            height: 18px;
            source: @image-url("assets/bluetooth.svg");
        }

        Image {
            visible: !root.bluetooth-connected;
            x: 496px;
            y: 7px;
            width: 15px;
            height: 18px;
            source: @image-url("assets/bluetooth.disconnected.svg");
        }

        RoundIconButton {
            x: 440px;
            y: 28px;
            width: 116px;
            height: 116px;
            border-radius: 58px;
            icon: @image-url("assets/settings.svg");
            title: "设置";
            subtitle: "";
            primary: true;
            clicked => { root.open-settings(); }
        }
    }

    Rectangle {
        visible: root.screen == 1;
        width: parent.width;
        height: parent.height;
        background: #050b14;

        PanelButton {
            x: 18px;
            y: 18px;
            width: 86px;
            label: "返回";
            clicked => { root.back-home(); }
        }

        Flickable {
            x: 126px;
            y: 18px;
            width: 496px;
            height: 142px;
            viewport-width: 640px;
            viewport-height: 142px;

            RoundIconButton {
                x: 0px;
                y: 4px;
                icon: @image-url("assets/wifi.svg");
                title: "WiFi";
                subtitle: "";
                primary: true;
                clicked => { root.open-wifi(); }
            }

            RoundIconButton {
                x: 156px;
                y: 4px;
                icon: @image-url("assets/bluetooth.svg");
                title: "蓝牙";
                subtitle: "";
                primary: true;
                clicked => { root.open-bluetooth(); }
            }

            RoundIconButton {
                x: 312px;
                y: 4px;
                icon: @image-url("assets/clock.svg");
                title: "时间";
                subtitle: "";
                primary: true;
                clicked => { root.open-time(); }
            }

            RoundIconButton {
                x: 468px;
                y: 4px;
                icon: @image-url("assets/info.svg");
                title: "关于";
                subtitle: "";
                primary: true;
                clicked => { root.open-about(); }
            }
        }

    }

    Rectangle {
        visible: root.screen == 2;
        width: parent.width;
        height: parent.height;
        background: #07111e;

        PanelButton { x: 10px; y: 10px; width: 72px; label: "返回"; clicked => { root.back-settings(); } }

        Text {
            x: 96px;
            y: 14px;
            width: 76px;
            height: 36px;
            text: "WiFi";
            color: #f8fbff;
            font-size: 22px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        PanelButton { x: 184px; y: 10px; width: 86px; label: root.wifi-enabled ? "关闭" : "打开"; primary: root.wifi-enabled; clicked => { root.wifi-toggle(); } }
        PanelButton { x: 282px; y: 10px; width: 86px; label: "扫描"; primary: true; clicked => { root.wifi-scan(); } }
        PanelButton { x: 380px; y: 10px; width: 86px; label: "连接"; primary: true; clicked => { root.wifi-connect(); } }
        PanelButton { x: 478px; y: 10px; width: 86px; label: "断开"; clicked => { root.wifi-disconnect(); } }
        PanelButton { x: 574px; y: 10px; width: 56px; label: "高级"; clicked => { root.open-wifi-advanced(); } }

        WifiRow { x: 16px; y: 60px; width: 372px; title: root.wifi-row0-title; detail: root.wifi-row0-detail; selected: root.wifi-row0-selected; clicked => { root.wifi-select-network(0); } }
        WifiRow { x: 16px; y: 108px; width: 372px; title: root.wifi-row1-title; detail: root.wifi-row1-detail; selected: root.wifi-row1-selected; clicked => { root.wifi-select-network(1); } }

        WifiRow { x: 402px; y: 60px; width: 214px; height: 42px; title: root.wifi-row2-title; detail: root.wifi-row2-detail; selected: root.wifi-row2-selected; clicked => { root.wifi-select-network(2); } }

        Text {
            x: 402px;
            y: 112px;
            width: 214px;
            height: 26px;
            text: root.wifi-status;
            color: root.wifi-connected ? #8dffbd : #ffd48d;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text {
            x: 402px;
            y: 138px;
            width: 214px;
            height: 18px;
            text: root.wifi-network-detail;
            color: #8ca5bb;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }

    Rectangle {
        visible: root.screen == 6;
        width: parent.width;
        height: parent.height;
        background: #07111e;

        PanelButton { x: 10px; y: 10px; width: 72px; label: "返回"; clicked => { root.open-wifi(); } }
        PanelButton { x: 94px; y: 10px; width: 82px; label: "SSID"; clicked => { root.wifi-edit-ssid(); } }
        PanelButton { x: 188px; y: 10px; width: 82px; label: "密码"; clicked => { root.wifi-edit-password(); } }
        PanelButton { x: 282px; y: 10px; width: 82px; label: "清空"; clicked => { root.wifi-clear-input(); } }
        PanelButton { x: 376px; y: 10px; width: 82px; label: "连接"; primary: true; clicked => { root.wifi-connect(); } }

        Text {
            x: 472px;
            y: 16px;
            width: 150px;
            height: 24px;
            text: "WiFi 高级";
            color: #f8fbff;
            font-size: 18px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Text { x: 16px; y: 54px; width: 260px; height: 20px; text: "SSID " + root.wifi-manual-ssid; color: root.wifi-edit-label == "编辑 SSID" ? #ffffff : #bde8ff; font-size: 13px; font-weight: 800; horizontal-alignment: left; vertical-alignment: center; }
        Text { x: 16px; y: 78px; width: 260px; height: 20px; text: "密码 " + root.wifi-password; color: root.wifi-edit-label == "编辑密码" ? #ffffff : #bde8ff; font-size: 13px; font-weight: 800; horizontal-alignment: left; vertical-alignment: center; }
        Text { x: 16px; y: 102px; width: 260px; height: 18px; text: root.wifi-edit-label + " " + root.wifi-key-page; color: #8ca5bb; font-size: 10px; font-weight: 700; horizontal-alignment: left; vertical-alignment: center; }

        KeyButton { x: 286px; y: 54px; label: root.wifi-key0; clicked => { root.wifi-key(root.wifi-key0); } }
        KeyButton { x: 334px; y: 54px; label: root.wifi-key1; clicked => { root.wifi-key(root.wifi-key1); } }
        KeyButton { x: 382px; y: 54px; label: root.wifi-key2; clicked => { root.wifi-key(root.wifi-key2); } }
        KeyButton { x: 430px; y: 54px; label: root.wifi-key3; clicked => { root.wifi-key(root.wifi-key3); } }
        KeyButton { x: 478px; y: 54px; label: root.wifi-key4; clicked => { root.wifi-key(root.wifi-key4); } }
        KeyButton { x: 526px; y: 54px; label: "删"; clicked => { root.wifi-backspace(); } }
        KeyButton { x: 286px; y: 104px; label: root.wifi-key5; clicked => { root.wifi-key(root.wifi-key5); } }
        KeyButton { x: 334px; y: 104px; label: root.wifi-key6; clicked => { root.wifi-key(root.wifi-key6); } }
        KeyButton { x: 382px; y: 104px; label: root.wifi-key7; clicked => { root.wifi-key(root.wifi-key7); } }
        KeyButton { x: 430px; y: 104px; label: root.wifi-key8; clicked => { root.wifi-key(root.wifi-key8); } }
        KeyButton { x: 478px; y: 104px; label: root.wifi-key9; clicked => { root.wifi-key(root.wifi-key9); } }
        KeyButton { x: 526px; y: 104px; label: "换"; clicked => { root.wifi-next-key-page(); } }
    }

    Rectangle {
        visible: root.screen == 3;
        width: parent.width;
        height: parent.height;
        background: #07111e;

        PanelButton { x: 18px; y: 18px; width: 84px; label: "返回"; clicked => { root.back-settings(); } }
        PanelButton { x: 126px; y: 18px; width: 112px; label: "重新广播"; primary: true; clicked => { root.bluetooth-refresh(); } }
        Text {
            x: 266px;
            y: 22px;
            width: 260px;
            height: 36px;
            text: "蓝牙";
            color: #f8fbff;
            font-size: 22px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
        Text {
            x: 266px;
            y: 68px;
            width: 300px;
            height: 34px;
            text: root.bluetooth-status;
            color: #f8fbff;
            font-size: 18px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }

    Rectangle {
        visible: root.screen == 4;
        width: parent.width;
        height: parent.height;
        background: #050b14;

        AdjustField { x: 8px; y: 21px; field-width: 76; label: "年"; value: root.year-text; increment => { root.adjust-year-up(); } decrement => { root.adjust-year-down(); } }
        AdjustField { x: 92px; y: 21px; label: "月"; value: root.month-text; increment => { root.adjust-month-up(); } decrement => { root.adjust-month-down(); } }
        AdjustField { x: 166px; y: 21px; label: "日"; value: root.day-text; increment => { root.adjust-day-up(); } decrement => { root.adjust-day-down(); } }
        AdjustField { x: 254px; y: 21px; label: "时"; value: root.hour-text; increment => { root.adjust-hour-up(); } decrement => { root.adjust-hour-down(); } }
        AdjustField { x: 328px; y: 21px; label: "分"; value: root.minute-text; increment => { root.adjust-minute-up(); } decrement => { root.adjust-minute-down(); } }
        AdjustField { x: 402px; y: 21px; label: "秒"; value: root.second-text; increment => { root.adjust-second-up(); } decrement => { root.adjust-second-down(); } }
        PanelButton { x: 488px; y: 39px; width: 94px; label: "保存"; primary: true; clicked => { root.confirm-adjust(); } }
        PanelButton { x: 488px; y: 91px; width: 94px; label: "取消"; clicked => { root.cancel-adjust(); } }
        Text {
            x: 486px;
            y: 132px;
            width: 120px;
            height: 18px;
            text: root.time-status;
            color: #9fb7cc;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }

    Rectangle {
        visible: root.screen == 5;
        width: parent.width;
        height: parent.height;
        background: #07111e;

        PanelButton { x: 18px; y: 18px; width: 84px; label: "返回"; clicked => { root.back-settings(); } }
        Text {
            x: 126px;
            y: 24px;
            width: 120px;
            height: 34px;
            text: "关于";
            color: #f8fbff;
            font-size: 22px;
            font-weight: 800;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
        Text {
            x: 126px;
            y: 68px;
            width: 310px;
            height: 64px;
            text: root.about-detail;
            color: #f8fbff;
            font-size: 15px;
            font-weight: 700;
            wrap: word-wrap;
            horizontal-alignment: left;
            vertical-alignment: center;
        }
    }
}
