export component AppWindow inherits Window {
    width: 640px;
    height: 172px;
    background: #101820;

    Text {
        width: parent.width;
        height: parent.height;
        text: "Hello World";
        color: white;
        font-size: 22px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
