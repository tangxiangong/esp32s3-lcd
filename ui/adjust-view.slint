import { ActionButton, FieldAdjuster } from "components.slint";

export component AdjustView inherits Rectangle {
    in property <string> year-text;
    in property <string> month-text;
    in property <string> day-text;
    in property <string> hour-text;
    in property <string> minute-text;
    in property <string> second-text;
    callback adjust-year-down;
    callback adjust-year-up;
    callback adjust-month-down;
    callback adjust-month-up;
    callback adjust-day-down;
    callback adjust-day-up;
    callback adjust-hour-down;
    callback adjust-hour-up;
    callback adjust-minute-down;
    callback adjust-minute-up;
    callback adjust-second-down;
    callback adjust-second-up;
    callback confirm-adjust;
    callback cancel-adjust;

    width: 640px;
    height: 172px;
    background: #070d14;

    Rectangle {
        x: 0px;
        y: 0px;
        width: 528px;
        height: 172px;
        background: #070d14;
    }

    Rectangle {
        x: 528px;
        y: 0px;
        width: 112px;
        height: 172px;
        background: #0b1320;
    }

    Rectangle {
        x: 527px;
        y: 20px;
        width: 1px;
        height: 132px;
        background: #132235;
    }

    FieldAdjuster {
        x: 16px;
        y: 16px;
        width: 84px;
        label: "YEAR";
        value: root.year-text;
        increment => { root.adjust-year-up(); }
        decrement => { root.adjust-year-down(); }
    }

    Text {
        x: 102px;
        y: 75px;
        width: 12px;
        height: 28px;
        text: "/";
        color: #7c95a8;
        font-size: 24px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    FieldAdjuster {
        x: 116px;
        y: 16px;
        width: 64px;
        label: "MON";
        value: root.month-text;
        increment => { root.adjust-month-up(); }
        decrement => { root.adjust-month-down(); }
    }

    Text {
        x: 182px;
        y: 75px;
        width: 12px;
        height: 28px;
        text: "/";
        color: #7c95a8;
        font-size: 24px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    FieldAdjuster {
        x: 196px;
        y: 16px;
        width: 64px;
        label: "DAY";
        value: root.day-text;
        increment => { root.adjust-day-up(); }
        decrement => { root.adjust-day-down(); }
    }

    Rectangle {
        x: 278px;
        y: 28px;
        width: 1px;
        height: 116px;
        background: #132235;
    }

    FieldAdjuster {
        x: 296px;
        y: 16px;
        width: 64px;
        label: "HOUR";
        value: root.hour-text;
        increment => { root.adjust-hour-up(); }
        decrement => { root.adjust-hour-down(); }
    }

    Text {
        x: 362px;
        y: 75px;
        width: 12px;
        height: 28px;
        text: ":";
        color: #7c95a8;
        font-size: 24px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    FieldAdjuster {
        x: 376px;
        y: 16px;
        width: 64px;
        label: "MIN";
        value: root.minute-text;
        increment => { root.adjust-minute-up(); }
        decrement => { root.adjust-minute-down(); }
    }

    Text {
        x: 442px;
        y: 75px;
        width: 12px;
        height: 28px;
        text: ":";
        color: #7c95a8;
        font-size: 24px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    FieldAdjuster {
        x: 456px;
        y: 16px;
        width: 64px;
        label: "SEC";
        value: root.second-text;
        increment => { root.adjust-second-up(); }
        decrement => { root.adjust-second-down(); }
    }

    ActionButton {
        x: 537px;
        y: 34px;
        label: "OK";
        primary: true;
        clicked => {
            root.confirm-adjust();
        }
    }

    ActionButton {
        x: 537px;
        y: 91px;
        label: "CANCEL";
        clicked => {
            root.cancel-adjust();
        }
    }
}
